# Copy to `.env.local` (or use `.env` — both are gitignored). Next.js loads `.env.local` automatically.
# The seed script and `npm run supabase:push` load `.env` first, then `.env.local` (local wins).

# --- Supabase (directory + map) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Seed script (`npm run seed:species`) — use service role for upserts without RLS friction
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI (`npm run supabase:push`) — personal access token, not the anon key
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token

# Optional: database password (Project Settings → Database) if `supabase link` needs it
# SUPABASE_DB_PASSWORD=

# Optional: explicit ref if URL is nonstandard
# SUPABASE_PROJECT_REF=your-project-ref

# Optional: URI connection string for external SQL clients (Settings → Database)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# --- Contact form (Cloudflare Turnstile) ---
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
